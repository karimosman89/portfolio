# ==========================================================================
#  Karim Osman — AI Engineer Portfolio · Environment Configuration
#  Copy this file to `.env` and fill in the values you need.
#  All AI + email features degrade gracefully if left unset.
# ==========================================================================

# --- Google Gemini (powers the AI Assistant chatbot & contact auto-reply) ---
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=""

# Optional: override the model used for chat / summaries / auto-reply.
# Examples: gemini-2.0-flash, gemini-1.5-flash, gemini-1.5-pro
GEMINI_MODEL="gemini-2.0-flash"

# --- Contact form email delivery (optional, via SMTP) ---
# If these are set, contact submissions are emailed to CONTACT_TO_EMAIL.
# If unset, submissions are still persisted to inquiries.json and the API
# responds successfully (with an AI acknowledgement).
# Example values shown are for a typical SMTP provider (SendGrid, Mailgun,
# Gmail App Password, Postmark, etc.).
SMTP_HOST=""            # e.g. smtp.sendgrid.net
SMTP_PORT="587"         # 587 (STARTTLS) or 465 (SSL)
SMTP_USER=""            # SMTP username / API key user
SMTP_PASS=""            # SMTP password / API key
CONTACT_TO_EMAIL="karim.programmer2020@gmail.com"

# --- App URL (self-referential links / deployment) ---
APP_URL="http://localhost:3000"

# --- Analytics (optional, privacy-friendly) ---
# Plausible or Umami domain, if you wire it up in index.html.
ANALYTICS_DOMAIN=""
